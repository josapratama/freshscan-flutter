# FreshScan API Keys - Template
# Salin file ini menjadi .env dan isi dengan key Anda

# Google Gemini Vision API
# Dapatkan di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API (alternatif Gemini)
# Dapatkan di: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Clarifai Food Recognition API
# Dapatkan di: https://clarifai.com/settings/security
CLARIFAI_API_KEY=your_clarifai_api_key_here
